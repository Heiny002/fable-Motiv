# Copy to .env and fill in values.

# SQLite database file (swap for Postgres in production via prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Secret used to sign JWT session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Anthropic API key for the AI coach. If unset, the app falls back to
# built-in template coaching so it still works end-to-end in development.
ANTHROPIC_API_KEY=""
