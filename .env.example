# Copy to .env and fill in values. In production, set these in Vercel:
# Project -> Settings -> Environment Variables.

# --- Supabase (server-side only; service role key must NEVER reach the client) ---
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# --- Auth ---
# Secret used to sign JWT session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- AI coach ---
# Your Anthropic API key. Without it, the coach responds with a setup notice
# instead of real coaching. Get one at https://platform.claude.com
ANTHROPIC_API_KEY=""

# --- Web push notifications (optional in dev) ---
# Generate a pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Cron (production) ---
# Random secret; Vercel Cron sends it so outsiders can't trigger notification runs.
CRON_SECRET=""
